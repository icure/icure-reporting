{
	"compilerOptions": {
		"target": "es2022",
		"module": "node16",
		"moduleResolution": "node16",
		"strict": true,
		"strictNullChecks": true,
		"noImplicitThis": true,
		"allowSyntheticDefaultImports": true,
		"lib": [
			"es2022"
		],
		"sourceMap": true,
		"declaration": true,
		"outDir": "./dist",
		"baseUrl": "./",
		"skipLibCheck": true
	},
	"include": [
		"src/**/*.ts"
	]
}
