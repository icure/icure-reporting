{
	"name": "@icure/reporting",
	"version": "1.0.0",
	"description": "",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"peg": "peggy -o dist/icure-reporting-parser.js grammar/icure-reporting-parser.peggy",
		"build": "yarn eslint && tsc",
		"start": "yarn build && node dist/icure-reporting.js",
		"eslint": "eslint src/*",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepare": "rm -rf dist && yarn build",
		"precommit": "pretty-quick --staged",
		"prePublish": "yarn prepare && jq '{name:.name, version:.version, description:.description, main:.main, types:.types, dependencies:.dependencies, author:.author, license:.license, bugs:.bugs, homepage:.homepage}' < package.json > dist/package.json",
		"publish": "yarn prePublish && cd dist && npm publish && cd .."
	},
	"bin": "dist/icure-reporting.js",
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@types/lodash": "^4.14.168",
		"@types/node": "^22.19.17",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"prettier": "^3.8.1",
		"pretty-quick": "^4.2.2",
		"typescript": "^5.9.3",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"@icure/api": "^8.6.14",
		"date-fns": "^2.3.0",
		"lodash": "^4.17.15",
		"peggy": "^5.1.0",
		"picocolors": "^1.1.1",
		"xlsx": "^0.15.1"
	},
	"prettier": {
		"semi": false,
		"printWidth": 100,
		"singleQuote": true
	},
	"packageManager": "yarn@4.13.0"
}
